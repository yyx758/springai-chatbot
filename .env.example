# ============================================
# AI Studio 环境变量配置
# 复制此文件为 .env 并填入你的实际值
# ============================================

# === 必填 ===

# DeepSeek API Key (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-api-key-here

# JWT 签名密钥 (至少 32 个字符)
APP_JWT_SECRET=your-random-secret-key-at-least-32-chars

# MySQL root 密码
MYSQL_ROOT_PASSWORD=your-mysql-password

# Redis 访问密码
REDIS_PASSWORD=your-redis-password

# SMTP 邮箱配置 (QQ 邮箱示例)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-email-auth-code

# === 可选 ===

# 是否启用 DeepSeek (true/false)
# SPRING_AI_OPENAI_ENABLED=false

# Ollama 地址 (本地或远程)
# SPRING_AI_OLLAMA_BASE_URL=http://localhost:11434

# RAG 模式: keyword / vector / hybrid (默认 hybrid)
# APP_RAG_MODE=hybrid

# Embedding API 配置 (阿里云 DashScope)
APP_RAG_EMBEDDING_PROVIDER=openai-compatible
APP_RAG_EMBEDDING_MODEL=text-embedding-v4
APP_RAG_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
APP_RAG_EMBEDDING_PATH=/v1/embeddings
APP_RAG_EMBEDDING_API_KEY=your-dashscope-api-key

# PGVector 配置 (默认已启用)
# APP_RAG_VECTOR_ENABLED=true
# APP_RAG_VECTOR_JDBC_URL=jdbc:postgresql://pgvector:5432/chatbot_vector
# PGVECTOR_DB=chatbot_vector
# PGVECTOR_USER=postgres
# PGVECTOR_PASSWORD=postgres

# 是否启用 Agent (true/false)
# APP_AGENT_ENABLED=true

# 是否启用 MCP Server (true/false)
# APP_MCP_SERVER_ENABLED=false

# 是否启用 Web Tools (true/false)
# APP_WEB_TOOLS_ENABLED=false
